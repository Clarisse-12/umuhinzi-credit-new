model Cooperative {
  id                 String               @id @default(uuid())
  name               String
  registrationNumber String?              @unique
  description        String?
  email              String?
  phone              String?
  address            String?
  province           String?
  district           String?
  sector             String?
  cell               String?
  village            String?
  status             CooperativeStatus    @default(PENDING)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  managers           CooperativeManager[]
  members            CooperativeMember[]
  farmers            Farmer[]

  @@index([status])
  @@index([district])
  @@index([sector])
  @@index([createdAt])
}

model CooperativeManager {
  id            String      @id @default(uuid())
  userId        String      @unique
  cooperativeId String
  position      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cooperativeId])
  @@index([createdAt])
}

model CooperativeMember {
  id            String                  @id @default(uuid())
  cooperativeId String
  farmerId      String                  @unique
  status        CooperativeMemberStatus @default(PENDING)
  joinedAt      DateTime?
  leftAt        DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  cooperative   Cooperative             @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  farmer        Farmer                  @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([cooperativeId])
  @@index([farmerId])
  @@index([status])
}

enum CooperativeStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum CooperativeMemberStatus {
  PENDING
  ACTIVE
  REMOVED
  LEFT
}
