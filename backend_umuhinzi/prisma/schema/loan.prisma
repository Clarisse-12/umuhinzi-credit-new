model LoanApplication {
  id                 String                @id @default(uuid())
  farmerId           String
  institutionId      String?
  creditScoreId      String?
  requestedAmount    Float
  recommendedAmount  Float?
  approvedAmount     Float?
  purpose            LoanPurpose
  purposeDescription String?
  status             LoanApplicationStatus @default(PENDING)
  reviewedById       String?
  reviewedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  loan               Loan?
  creditScore        CreditScore?          @relation(fields: [creditScoreId], references: [id])
  farmer             Farmer                @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  institution        Institution?          @relation(fields: [institutionId], references: [id])
  reviewedBy         User?                 @relation(fields: [reviewedById], references: [id])

  @@index([farmerId])
  @@index([institutionId])
  @@index([creditScoreId])
  @@index([reviewedById])
  @@index([status])
  @@index([purpose])
  @@index([createdAt])
}

model Loan {
  id                 String              @id @default(uuid())
  loanApplicationId  String              @unique
  farmerId           String
  institutionId      String?
  principalAmount    Float
  interestRate       Float               @default(0)
  totalPayable       Float
  disbursedAmount    Float?
  disbursedAt        DateTime?
  startDate          DateTime?
  endDate            DateTime?
  status             LoanStatus          @default(APPROVED)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  farmer             Farmer              @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  institution        Institution?        @relation(fields: [institutionId], references: [id])
  loanApplication    LoanApplication     @relation(fields: [loanApplicationId], references: [id], onDelete: Cascade)
  statusHistory      LoanStatusHistory[]
  repayments         Repayment[]
  repaymentSchedules RepaymentSchedule[]

  @@index([farmerId])
  @@index([institutionId])
  @@index([status])
  @@index([disbursedAt])
  @@index([createdAt])
}

model LoanStatusHistory {
  id          String     @id @default(uuid())
  loanId      String
  status      LoanStatus
  changedById String?
  note        String?
  createdAt   DateTime   @default(now())
  changedBy   User?      @relation(fields: [changedById], references: [id])
  loan        Loan       @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([changedById])
  @@index([status])
  @@index([createdAt])
}

enum LoanApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum LoanStatus {
  APPROVED
  DISBURSED
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
}

enum LoanPurpose {
  SEEDS
  FERTILIZER
  EQUIPMENT
  IRRIGATION
  LIVESTOCK
  LAND_RENT
  LABOR
  TRANSPORT
  STORAGE
  OTHER
}
