model InputCost {
  id          String    @id @default(uuid())
  cropId      String
  type        InputType
  name        String
  description String?
  quantity    Float?
  unit        String?
  unitCost    Float?
  totalCost   Float
  dateUsed    DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  crop        Crop      @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@index([cropId])
  @@index([type])
  @@index([dateUsed])
  @@index([createdAt])
}

enum InputType {
  SEED
  FERTILIZER
  PESTICIDE
  HERBICIDE
  LABOR
  IRRIGATION
  TRANSPORT
  EQUIPMENT
  STORAGE
  OTHER
}
